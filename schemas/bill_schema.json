{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-geode.local/schemas/bill_schema.json",
  "title": "Project Geode Parsed and Enriched Bill Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bill_number",
    "title",
    "sponsors",
    "sections",
    "crs_references",
    "effective_date",
    "appropriations",
    "metadata",
    "entities"
  ],
  "properties": {
    "bill_number": {
      "type": "string",
      "pattern": "^(HB|SB)\\d{2}-\\d{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "sponsors": {
      "$ref": "#/$defs/sponsors"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "crs_references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/crs_reference"
      },
      "uniqueItems": true
    },
    "effective_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "appropriations": {
      "oneOf": [
        {
          "$ref": "#/$defs/appropriations"
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "entities": {
      "$ref": "#/$defs/entities"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "crs_reference": {
      "type": "string",
      "pattern": "^\\u00a7\\s+\\d{1,2}(?:\\.\\d+)?-\\d{1,3}(?:\\.\\d+)?-\\d{1,4}(?:\\.\\d+)?,\\s+C\\.R\\.S\\.$"
    },
    "sponsors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "house_sponsors",
        "senate_sponsors"
      ],
      "properties": {
        "house_sponsors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "senate_sponsors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_number",
        "text",
        "crs_references",
        "action"
      ],
      "properties": {
        "section_number": {
          "type": "integer",
          "minimum": 1
        },
        "heading": {
          "type": [
            "string",
            "null"
          ]
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "crs_references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/crs_reference"
          },
          "uniqueItems": true
        },
        "action": {
          "enum": [
            "amend",
            "add",
            "repeal",
            "new",
            null
          ]
        }
      }
    },
    "appropriations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "has_appropriation",
        "amounts"
      ],
      "properties": {
        "has_appropriation": {
          "type": "boolean"
        },
        "amounts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/appropriation_amount"
          }
        }
      }
    },
    "appropriation_amount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "fund"
      ],
      "properties": {
        "amount": {
          "$ref": "#/$defs/non_empty_string"
        },
        "fund": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "page_count",
        "parse_timestamp",
        "parser_version"
      ],
      "properties": {
        "source_file": {
          "$ref": "#/$defs/non_empty_string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 0
        },
        "parse_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "parser_version": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "entities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "committees",
        "dates",
        "fiscal_impact",
        "penalties",
        "definitions"
      ],
      "properties": {
        "committees": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/committee_entity"
          }
        },
        "dates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/date_entity"
          }
        },
        "fiscal_impact": {
          "oneOf": [
            {
              "$ref": "#/$defs/fiscal_impact"
            },
            {
              "type": "null"
            }
          ]
        },
        "penalties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/penalty_entity"
          }
        },
        "definitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/definition_entity"
          }
        }
      }
    },
    "committee_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "committee",
        "chamber",
        "context"
      ],
      "properties": {
        "committee": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chamber": {
          "enum": [
            "house",
            "senate"
          ]
        },
        "context": {
          "type": "string"
        }
      }
    },
    "date_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_text",
        "normalized",
        "context"
      ],
      "properties": {
        "raw_text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "normalized": {
          "$ref": "#/$defs/non_empty_string"
        },
        "context": {
          "type": "string"
        }
      }
    },
    "fiscal_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dollar_amounts",
        "fte_mentions",
        "fund_names"
      ],
      "properties": {
        "dollar_amounts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dollar_amount"
          }
        },
        "fte_mentions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "fund_names": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "dollar_amount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "context"
      ],
      "properties": {
        "amount": {
          "$ref": "#/$defs/non_empty_string"
        },
        "context": {
          "type": "string"
        }
      }
    },
    "penalty_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "detail",
        "context"
      ],
      "properties": {
        "type": {
          "enum": [
            "misdemeanor",
            "felony",
            "fine",
            "other"
          ]
        },
        "detail": {
          "$ref": "#/$defs/non_empty_string"
        },
        "context": {
          "type": "string"
        }
      }
    },
    "definition_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term",
        "definition",
        "section"
      ],
      "properties": {
        "term": {
          "$ref": "#/$defs/non_empty_string"
        },
        "definition": {
          "$ref": "#/$defs/non_empty_string"
        },
        "section": {
          "type": "string"
        }
      }
    }
  }
}
