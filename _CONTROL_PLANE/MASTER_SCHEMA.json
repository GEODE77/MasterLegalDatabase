{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-geode.local/schema/master.schema.json",
  "title": "Project Geode Master Schema",
  "description": "Formal JSON Schema definitions for Project Geode legal authority records.",
  "type": "object",
  "oneOf": [
    {"$ref": "#/$defs/statute_section"},
    {"$ref": "#/$defs/regulation_rule"},
    {"$ref": "#/$defs/bill"},
    {"$ref": "#/$defs/rulemaking_notice"},
    {"$ref": "#/$defs/executive_order"},
    {"$ref": "#/$defs/session_law"},
    {"$ref": "#/$defs/ag_opinion"},
    {"$ref": "#/$defs/coprrr_review"},
    {"$ref": "#/$defs/rule_unit"},
    {"$ref": "#/$defs/crosswalk_entry"},
    {"$ref": "#/$defs/timeline_event"},
    {"$ref": "#/$defs/agency"},
    {"$ref": "#/$defs/local_authority"},
    {"$ref": "#/$defs/local_rule"},
    {"$ref": "#/$defs/county_gap"}
  ],
  "$defs": {
    "ConfidenceScore": {
      "type": "object",
      "description": "Per-record and optional per-field confidence scores.",
      "additionalProperties": false,
      "required": ["overall"],
      "properties": {
        "overall": {
          "type": "number",
          "description": "Overall confidence from 0.0 to 1.0.",
          "minimum": 0,
          "maximum": 1
        },
        "fields": {
          "type": "object",
          "description": "Optional field-level confidence values keyed by field name.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "route": {
          "type": "string",
          "description": "Optional pipeline routing outcome.",
          "enum": ["auto_accept", "flag_accept", "quarantine", "reject"]
        }
      }
    },
    "Sponsor": {
      "type": "object",
      "description": "Legislative bill sponsor.",
      "additionalProperties": false,
      "required": ["name", "chamber", "role"],
      "properties": {
        "name": {"type": "string", "description": "Sponsor display name."},
        "party": {"type": ["string", "null"], "description": "Political party if known."},
        "chamber": {
          "type": "string",
          "description": "Legislative chamber.",
          "enum": ["Senate", "House"]
        },
        "role": {"type": "string", "description": "Sponsor role, such as primary."}
      }
    },
    "HistoryEvent": {
      "type": "object",
      "description": "One chronological amendment-history event.",
      "additionalProperties": false,
      "required": ["date", "action"],
      "properties": {
        "date": {"type": "string", "description": "Event date.", "format": "date"},
        "action": {"type": "string", "description": "Action taken on the entity."},
        "bill": {"type": ["string", "null"], "description": "Bill ID, if applicable."}
      }
    },
    "statute_section": {
      "type": "object",
      "description": "A Colorado Revised Statutes section.",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "id",
        "title_num",
        "title_name",
        "article_num",
        "article_name",
        "section_num",
        "section_heading",
        "full_text",
        "subject_tags",
        "industry_tags",
        "source_url",
        "data_retrieved",
        "data_version",
        "confidence"
      ],
      "properties": {
        "entity_type": {
          "const": "statute_section",
          "description": "Entity type discriminator."
        },
        "id": {
          "type": "string",
          "description": "Canonical CRS section ID.",
          "pattern": "^CRS-[0-9]{1,2}(?:\\.[0-9]+)?-[0-9]+(?:\\.[0-9]+)?-[0-9]+(?:\\.[0-9]+)?$"
        },
        "title_num": {"type": "integer", "description": "CRS title number from 1 to 44."},
        "title_name": {"type": "string", "description": "Official CRS title name."},
        "article_num": {"type": "integer", "description": "CRS article number."},
        "article_name": {"type": "string", "description": "Official article name."},
        "part_num": {"type": ["integer", "null"], "description": "Part number if present."},
        "part_name": {"type": ["string", "null"], "description": "Part name if present."},
        "section_num": {"type": "string", "description": "Full official section number."},
        "section_heading": {"type": "string", "description": "Official section heading."},
        "full_text": {"type": "string", "description": "Complete unmodified legal text."},
        "effective_date": {
          "type": ["string", "null"],
          "description": "Date this version took effect if known.",
          "format": "date"
        },
        "last_amended_session": {
          "type": ["string", "null"],
          "description": "Session year of the last known amendment."
        },
        "last_amended_by": {
          "type": "array",
          "description": "Bill IDs that last amended the section.",
          "items": {"type": "string"}
        },
        "history_note": {
          "type": ["string", "null"],
          "description": "Legislative history note."
        },
        "subject_tags": {
          "type": "array",
          "description": "Ontology subject tags.",
          "items": {"type": "string"}
        },
        "industry_tags": {
          "type": "array",
          "description": "Ontology industry tags.",
          "items": {"type": "string"}
        },
        "cross_references_outbound": {
          "type": "array",
          "description": "Canonical IDs referenced by this section.",
          "items": {"type": "string"}
        },
        "enabling_agencies": {
          "type": "array",
          "description": "Agency IDs enabled or governed by this section.",
          "items": {"type": "string"}
        },
        "related_regulations": {
          "type": "array",
          "description": "CCR regulation IDs related to this section.",
          "items": {"type": "string"}
        },
        "source_url": {"type": "string", "description": "Official source URL.", "format": "uri"},
        "data_retrieved": {
          "type": "string",
          "description": "Date the data was retrieved.",
          "format": "date"
        },
        "data_version": {"type": "string", "description": "Source data version ID."},
        "confidence": {"$ref": "#/$defs/ConfidenceScore"}
      },
      "examples": [
        {
          "entity_type": "statute_section",
          "id": "CRS-25-7-109",
          "title_num": 25,
          "title_name": "Public Health and Environment",
          "article_num": 7,
          "article_name": "Air Quality Control",
          "part_num": null,
          "part_name": null,
          "section_num": "25-7-109",
          "section_heading": "Emission control regulations",
          "full_text": "(1) The commission shall promulgate...",
          "effective_date": "2023-07-01",
          "last_amended_session": "2023",
          "last_amended_by": ["SB23-016"],
          "history_note": null,
          "subject_tags": ["air_quality", "emissions"],
          "industry_tags": ["manufacturing", "energy"],
          "cross_references_outbound": [],
          "enabling_agencies": [],
          "related_regulations": [],
          "source_url": "https://leg.colorado.gov/colorado-revised-statutes",
          "data_retrieved": "2026-06-10",
          "data_version": "2025_session_final",
          "confidence": {"overall": 0.95}
        }
      ]
    },
    "regulation_rule": {
      "type": "object",
      "description": "An administrative rule from the Code of Colorado Regulations.",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "id",
        "ccr_number",
        "title",
        "department",
        "department_code",
        "agency",
        "agency_code",
        "enabling_statutes",
        "effective_date",
        "status",
        "full_text",
        "chunk_level_3_summary",
        "subject_tags",
        "industry_tags",
        "source_url",
        "source_format",
        "extraction_method",
        "confidence"
      ],
      "properties": {
        "entity_type": {"const": "regulation_rule", "description": "Entity type discriminator."},
        "id": {
          "type": "string",
          "description": "Canonical CCR rule ID.",
          "pattern": "^[0-9]{1,2}_CCR_[0-9]+-[0-9]+(?:-[0-9]+)?$"
        },
        "ccr_number": {"type": "string", "description": "Official CCR number."},
        "title": {"type": "string", "description": "Rule title."},
        "department": {"type": "string", "description": "Department name."},
        "department_code": {"type": "string", "description": "Department numeric code."},
        "agency": {"type": "string", "description": "Issuing agency."},
        "agency_code": {"type": "string", "description": "Agency code from registry."},
        "enabling_statutes": {
          "type": "array",
          "description": "CRS IDs authorizing the rule.",
          "items": {"type": "string"}
        },
        "effective_date": {"type": "string", "description": "Effective date.", "format": "date"},
        "status": {
          "type": "string",
          "description": "Rule status.",
          "enum": ["active", "repealed", "superseded", "emergency", "expired"]
        },
        "full_text": {"type": "string", "description": "Complete rule text."},
        "chunk_level_3_summary": {
          "type": "string",
          "description": "Plain-English discovery summary."
        },
        "subject_tags": {
          "type": "array",
          "description": "Ontology subject tags.",
          "items": {"type": "string"}
        },
        "industry_tags": {
          "type": "array",
          "description": "Ontology industry tags.",
          "items": {"type": "string"}
        },
        "compliance_keywords": {
          "type": "array",
          "description": "Ontology compliance keywords.",
          "items": {"type": "string"}
        },
        "source_url": {"type": "string", "description": "Official source URL.", "format": "uri"},
        "source_format": {
          "type": "string",
          "description": "Original source format.",
          "enum": ["pdf", "docx"]
        },
        "extraction_method": {"type": "string", "description": "Extraction method name."},
        "confidence": {"$ref": "#/$defs/ConfidenceScore"}
      },
      "examples": [
        {
          "entity_type": "regulation_rule",
          "id": "5_CCR_1001-9",
          "ccr_number": "5 CCR 1001-9",
          "title": "Regulation 3 - Stationary Source Permitting",
          "department": "Public Health and Environment",
          "department_code": "1000",
          "agency": "Air Quality Control Commission",
          "agency_code": "CDPHE_AQCC",
          "enabling_statutes": ["CRS-25-7-109", "CRS-25-7-110"],
          "effective_date": "2024-01-15",
          "status": "active",
          "full_text": "PART A...",
          "chunk_level_3_summary": "Establishes permitting for stationary air pollution sources.",
          "subject_tags": ["air_quality", "permitting"],
          "industry_tags": ["manufacturing", "energy"],
          "compliance_keywords": ["permit_required"],
          "source_url": "https://www.sos.state.co.us/CCR/Welcome.do",
          "source_format": "docx",
          "extraction_method": "docx_structural_parse",
          "confidence": {"overall": 0.94}
        }
      ]
    },
    "bill": {
      "type": "object",
      "description": "A Colorado legislative bill.",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "id",
        "session",
        "chamber",
        "bill_number",
        "title",
        "sponsors",
        "status",
        "status_date",
        "introduced_date",
        "subject_tags",
        "source_url",
        "confidence"
      ],
      "properties": {
        "entity_type": {"const": "bill", "description": "Entity type discriminator."},
        "id": {
          "type": "string",
          "description": "Canonical bill ID.",
          "pattern": "^(SB|HB|SCR|HCR|SJR|HJR)[0-9]{2}-[0-9]{3}$"
        },
        "session": {"type": "string", "description": "Legislative session year."},
        "chamber": {
          "type": "string",
          "description": "Origin chamber.",
          "enum": ["Senate", "House"]
        },
        "bill_number": {"type": "string", "description": "Bill number."},
        "title": {"type": "string", "description": "Short bill title."},
        "sponsors": {
          "type": "array",
          "description": "Bill sponsor records.",
          "items": {"$ref": "#/$defs/Sponsor"}
        },
        "status": {
          "type": "string",
          "description": "Current bill status.",
          "enum": ["signed", "vetoed", "in_committee", "active", "expired"]
        },
        "status_date": {"type": "string", "description": "Latest status date.", "format": "date"},
        "introduced_date": {"type": "string", "description": "Introduction date.", "format": "date"},
        "statutes_amended": {
          "type": "array",
