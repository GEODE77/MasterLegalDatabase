          "items": {"type": "string"}
        },
        "subject_tags": {
          "type": "array",
          "description": "Ontology subject tags.",
          "items": {"type": "string"}
        },
        "source_url": {"type": "string", "description": "LegiScan or official source URL.", "format": "uri"},
        "confidence": {"$ref": "#/$defs/ConfidenceScore"}
      },
      "examples": [
